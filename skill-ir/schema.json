{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Skill OS IR",
  "type": "object",
  "required": [
    "schema_version",
    "name",
    "version",
    "job_to_be_done",
    "skill_path",
    "required_output_sections",
    "trigger_surface",
    "workflow",
    "resources",
    "eval_plan",
    "risk",
    "governance",
    "registry_package"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "pattern": "^1\\.0$"
    },
    "name": {
      "type": "string",
      "minLength": 1
    },
    "version": {
      "type": "string",
      "minLength": 1
    },
    "job_to_be_done": {
      "type": "string",
      "minLength": 20
    },
    "skill_path": {
      "type": "string",
      "minLength": 1
    },
    "required_output_sections": {
      "type": "array",
      "minItems": 5,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "trigger_surface": {
      "type": "object",
      "required": [
        "should_trigger",
        "should_not_trigger",
        "edge_cases"
      ],
      "properties": {
        "should_trigger": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "should_not_trigger": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "edge_cases": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "workflow": {
      "type": "object",
      "required": [
        "steps"
      ],
      "properties": {
        "steps": {
          "type": "array",
          "minItems": 3,
          "items": {
            "type": "object",
            "required": [
              "id",
              "title",
              "outcome"
            ],
            "properties": {
              "id": {
                "type": "string",
                "minLength": 1
              },
              "title": {
                "type": "string",
                "minLength": 1
              },
              "outcome": {
                "type": "string",
                "minLength": 1
              }
            }
          }
        }
      }
    },
    "resources": {
      "type": "object",
      "required": [
        "references",
        "scripts",
        "reports"
      ],
      "properties": {
        "references": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "scripts": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "reports": {
          "type": "array",
          "minItems": 4,
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "eval_plan": {
      "type": "object",
      "required": [
        "trigger",
        "output"
      ],
      "properties": {
        "trigger": {
          "type": "string",
          "minLength": 1
        },
        "output": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "risk": {
      "type": "object",
      "required": [
        "output_risk",
        "execution_risk",
        "trust_boundary"
      ],
      "properties": {
        "output_risk": {
          "type": "string",
          "minLength": 1
        },
        "execution_risk": {
          "type": "string",
          "minLength": 1
        },
        "trust_boundary": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "governance": {
      "type": "object",
      "required": [
        "owner",
        "maturity",
        "review_cadence"
      ],
      "properties": {
        "owner": {
          "type": "string",
          "minLength": 1
        },
        "maturity": {
          "type": "string",
          "minLength": 1
        },
        "review_cadence": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "registry_package": {
      "type": "string",
      "minLength": 1
    }
  },
  "additionalProperties": true
}
